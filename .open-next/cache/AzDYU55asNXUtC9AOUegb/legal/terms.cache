{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/legal/layout,_N_T_/legal/terms/layout,_N_T_/legal/terms/page,_N_T_/legal/terms"},"segmentPaths":["/_tree","/_full","/legal/terms/__PAGE__","/legal/terms","/legal","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\" class=\"h-full antialiased fraunces_b7a1ed3b-module__417h6G__variable public_sans_97488c5b-module__BMdkga__variable\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/54fc36028e2bb174-s.p.0nkps02--w45i.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/fa0520225c6f3d07-s.p.0_88erakuzr64.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/0tbn~grm7is_3.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/0hvu8ydxmxc5p.js\"/><script src=\"/_next/static/chunks/07a5.0nvzpi-7.js\" async=\"\"></script><script src=\"/_next/static/chunks/0l6.~rw659v~2.js\" async=\"\"></script><script src=\"/_next/static/chunks/0fe-lb5inkx1f.js\" async=\"\"></script><script src=\"/_next/static/chunks/0.d122b2i~ony.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-0dr6g4p68z71f.js\" async=\"\"></script><script src=\"/_next/static/chunks/001b~5_czkb82.js\" async=\"\"></script><script src=\"/_next/static/chunks/0zukl~qek1swj.js\" async=\"\"></script><meta name=\"next-size-adjust\" content=\"\"/><title>Terms of Service | OpenGolfAPI</title><meta name=\"description\" content=\"Terms of Service for OpenGolfAPI — a free, community-maintained, ODbL-licensed open dataset of US golf courses.\"/><meta property=\"og:title\" content=\"OpenGolfAPI — The Open Golf Course Database\"/><meta property=\"og:description\" content=\"Terms of Service for OpenGolfAPI — a free, community-maintained, ODbL-licensed open dataset of US golf courses.\"/><meta property=\"og:site_name\" content=\"OpenGolfAPI\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary\"/><meta name=\"twitter:title\" content=\"OpenGolfAPI — The Open Golf Course Database\"/><meta name=\"twitter:description\" content=\"Terms of Service for OpenGolfAPI — a free, community-maintained, ODbL-licensed open dataset of US golf courses.\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.0x3dzn~oxb6tn.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><script src=\"/_next/static/chunks/03~yq9q893hmn.js\" noModule=\"\"></script></head><body class=\"min-h-full flex flex-col\"><div hidden=\"\"><!--$--><!--/$--></div><header class=\"bg-cream border-b border-cream-darkest\" style=\"background:var(--color-cream);border-color:var(--color-cream-darkest)\"><nav class=\"max-w-[1100px] mx-auto px-6 h-16 flex items-center justify-between\"><a class=\"font-display text-[22px] font-bold tracking-tight\" style=\"color:var(--color-evergreen-950)\" href=\"/\">Open<em style=\"color:var(--color-brass-700);font-style:italic\">Golf</em>API</a><div class=\"flex items-center gap-6 text-sm\" style=\"color:var(--color-ink-muted)\"><details class=\"relative group [&amp;[open]&gt;summary&gt;span]:rotate-180\"><summary class=\"list-none cursor-pointer hover:text-[var(--color-evergreen-950)] transition-colors inline-flex items-center gap-1 select-none\">Browse<span class=\"text-[10px] transition-transform duration-150\" aria-hidden=\"true\">▾</span></summary><div class=\"absolute right-0 top-full mt-2 z-50\"><div class=\"grid grid-cols-5 gap-1 p-3 bg-white rounded-md shadow-xl border\" style=\"border-color:var(--color-cream-darkest)\"><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/al\">AL</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\