a\">LA</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/me\">ME</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/md\">MD</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/ma\">MA</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/mi\">MI</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/mn\">MN</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/ms\">MS</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/mo\">MO</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/mt\">MT</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/ne\">NE</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/nv\">NV</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/nh\">NH</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/nj\">NJ</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/nm\">NM</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/ny\">NY</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/nc\">NC</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/nd\">ND</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/oh\">OH</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/ok\">OK</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/or\">OR</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/pa\">PA</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/ri\">RI</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/sc\">SC</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/sd\">SD</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/tn\">TN</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/tx\">TX</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/ut\">UT</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/vt\">VT</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/va\">VA</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/wa\">WA</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/wv\">WV</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/wi\">WI</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/wy\">WY</a><a class=\"px-2 py-1 text-xs rounded hover:bg-[var(--color-cream)]\" style=\"color:var(--color-ink)\" href=\"/courses/dc\">DC</a></div></div></details><a class=\"hover:text-[var(--color-evergreen-950)] transition-colors\" href=\"/search\">Search</a><a class=\"hover:text-[var(--color-evergreen-950)] transition-colors\" href=\"/near-me\">Near me</a><a href=\"https://opengolfapi.org/#api\" class=\"hover:text-[var(--color-evergreen-950)] transition-colors\">API</a><a class=\"px-3 py-1.5 rounded text-sm font-semibold\" style=\"background:var(--color-evergreen-950);color:var(--color-cream)\" href=\"/submit\">Submit</a></div></nav></header><main class=\"flex-1\"><div class=\"max-w-[1100px] mx-auto px-6 pt-12 pb-16\"><p class=\"font-display italic text-[15px] mb-3\" style=\"color:var(--color-brass-700);font-variation-settings:&quot;opsz&quot; 14\">Donations, not paywalls</p><h1 class=\"font-display tracking-tight font-bold mb-4\" style=\"font-size:clamp(36px, 5vw, 60px);line-height:1.05\">Pay what helps the<!-- --> <em style=\"color:var(--color-brass-700);font-style:italic\">almanac grow.</em></h1><p class=\"text-lg mb-3 max-w-[640px]\" style=\"color:var(--color-ink-muted)\">OpenGolfAPI is free to use, free to fork, and licensed under ODbL forever. The tiers below exist so the people who lean on the data hardest can keep the lights on for everyone else.</p><p class=\"text-lg mb-12 max-w-[640px]\" style=\"color:var(--color-ink-muted)\">Higher tiers come with higher rate limits and a thank-you in the credits — never with access to data that the free tier doesn&#x27;t already have.</p><div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5\"><article class=\"rounded-sm p-8 flex flex-col h-full\" style=\"border-style:solid;border-color:var(--color-cream-darkest);border-width:1px;background:var(--color-cream)\"><p class=\"text-[13px] mb-2\" style=\"color:transparent\"> </p><h2 class=\"font-display text-2xl font-bold mb-3\" style=\"color:var(--color-ink)\">Anonymous</h2><div class=\"mb-6 flex items-baseline gap-2\"><span class=\"font-display font-bold\" style=\"font-size:clamp(32px, 3.5vw, 44px);line-height:1;color:var(--color-ink)\">$0</span><span class=\"text-sm\" style=\"color:var(--color-ink-muted)\">forever</span></div><dl class=\"space-y-4 mb-8 text-[15px]\" style=\"color:var(--color-ink)\"><div><dt class=\"text-[11px] font-semibold tracking-wider uppercase mb-1\" style=\"color:var(--color-ink-muted)\">Rate limit</dt><dd>1,000 requests per day, per IP address.</dd></div><div><dt class=\"text-[11px] font-semibold tracking-wider uppercase mb-1\" style=\"color:var(--color-ink-muted)\">How to sign up</dt><dd>No signup, no email, no key. Just hit the endpoint.</dd></div><div><dt class=\"text-[11px] font-semibold tracking-wider uppercase mb-1\" style=\"color:var(--color-ink-muted)\">Recognition</dt><dd>We won&#x27;t know who you are, and that&#x27;s fine — the dataset is free for everyone.</dd></div></dl><div class=\"mt-auto\"><a href=\"https://opengolfapi.org/#api\" target=\"_blank\" rel=\"noopener\" class=\"inline-block w-full text-center px-5 py-2.5 text-sm font-semibold rounded-sm transition-colors hover:opacity-90\" style=\"background:transparent;color:var(--color-evergreen-950);border:1px solid var(--color-evergreen-950)\">Read the docs</a></div></article><article class=\"rounded-sm p-8 flex flex-col h-full\" style=\"border-style:solid;border-color:var(--color-brass-500);border-width:2px;background:var(--color-cream)\"><p class=\"font-display italic text-[13px] mb-2\" style=\"color:var(--color-brass-700);font-variation-settings:&quot;opsz&quot; 14\">Most developers start here</p><h2 class=\"font-display text-2xl font-bold mb-3\" style=\"color:var(--color-ink)\">Keyed</h2><div class=\"mb-6 flex items-baseline gap-2\"><span class=\"font-display font-bold\" style=\"font-size:clamp(32px, 3.5vw, 44px);line-height:1;color:var(--color-ink)\">$0</span><span class=\"text-sm\" style=\"color:var(--color-ink-muted)\">forever</span></div><dl class=\"space-y-4 mb-8 text-[15px]\" style=\"color:var(--color-ink)\"><div><dt class=\"text-[11px] font-semibold tracking-wider uppercase mb-1\" style=\"color:var(--color-ink-muted)\">Rate limit</dt><dd>10,000 requests per day, attached to your key.</dd></div><div><dt class=\"text-[11px] font-semibold tracking-wider uppercase mb-1\" style=\"color:var(--color-ink-muted)\">How to sign up</dt><dd>Drop an email at /api-keys and we&#x27;ll generate a key on the spot.</dd></div><div><dt class=\"text-[11px] font-semibold tracking-wider uppercase mb-1\" style=\"color:var(--color-ink-muted)\">Recognition</dt><dd>We&#x27;ll email you ahead of any breaking change so your integration never wakes up broken.</dd></div></dl><div class=\"mt-auto\"><a class=\"inline-block w-full text-center px-5 py-2.5 text-sm font-semibold rounded-sm transition-colors hover:opacity-90\" style=\"background:transparent;color:var(--color-evergreen-950);border:1px solid var(--color-evergreen-950)\" href=\"/api-keys\">Get a free key</a></div></article><article class=\"rounded-sm p-8 flex flex-col h-full\" style=\"border-style:solid;border-color:var(--color-cream-darkest);border-width:1px;background:var(--color-cream)\"><p class=\"text-[13px] mb-2\" style=\"color:transparent\"> </p><h2 class=\"font-display text-2xl font-bold mb-3\" style=\"color:var(--color-ink)\">Backer</h2><div class=\"mb-6 flex items-baseline gap-2\"><span class=\"font-display font-bold\" style=\"font-size:clamp(32px, 3.5vw, 44px);line-height:1;color:var(--color-ink)\">$10</span><span class=\"text-sm\" style=\"color:var(--color-ink-muted)\">per month</span></div><dl class=\"space-y-4 mb-8 text-[15px]\" style=\"color:var(--color-ink)\"><div><dt class=\"text-[11px] font-semibold tracking-wider uppercase mb-1\" style=\"color:var(--color-ink-muted)\">Rate limit</dt><dd>50,000 requests per day.</dd></div><div><dt class=\"text-[11px] font-semibold tracking-wider uppercase mb-1\" style=\"color:var(--color-ink-muted)\">How to sign up</dt><dd>Pledge on Open Collective, then send the matching email so we can lift your limit.</dd></div><div><dt class=\"text-[11px] font-semibold tracking-wider uppercase mb-1\" style=\"color:var(--color-ink-muted)\">Recognition</dt><dd>Your name on the /supporters page — a small, permanent thank-you in the credits of the dataset.</dd></div></dl><div class=\"mt-auto\"><a href=\"https://opencollective.com/opengolfapi\" target=\"_blank\" rel=\"noopener\" class=\"inline-block w-full text-center px-5 py-2.5 text-sm font-semibold rounded-sm transition-colors hover:opacity-90\" style=\"background:transparent;color:var(--color-evergreen-950);border:1px solid var(--color-evergreen-950)\">Become a backer</a></div></article><article class=\"rounded-sm p-8 flex flex-col h-full\" style=\"border-style:solid;border-color:var(--color-evergreen-700);border-width:2px;background:var(--color-cream)\"><p class=\"font-display italic text-[13px] mb-2\" style=\"color:var(--color-brass-700);font-variation-settings:&quot;opsz&quot; 14\">Most popular</p><h2 class=\"font-display text-2xl font-bold mb-3\" style=\"color:var(--color-ink)\">Sponsor</h2><div class=\"mb-6 flex items-baseline gap-2\"><span class=\"font-display font-bold\" style=\"font-size:clamp(32px, 3.5vw, 44px);line-height:1;color:var(--color-ink)\">$50</span><span class=\"text-sm\" style=\"color:var(--color-ink-muted)\">per month</span></div><dl class=\"space-y-4 mb-8 text-[15px]\" style=\"color:var(--color-ink)\"><div><dt class=\"text-[11px] font-semibold tracking-wider uppercase mb-1\" style=\"color:var(--color-ink-muted)\">Rate limit</dt><dd>250,000 requests per day.</dd></div><div><dt class=\"text-[11px] font-semibold tracking-wider uppercase mb-1\" style=\"color:var(--color-ink-muted)\">How to sign up</dt><dd>Pledge on Open Collective.</dd></div><div><dt class=\"text-[11px] font-semibold tracking-wider uppercase mb-1\" style=\"color:var(--color-ink-muted)\">Recognition</dt><dd>Your logo on the /supporters page and a thank-you in every release note we publish.</dd></div></dl><div class=\"mt-auto\"><a href=\"https://opencollective.com/opengolfapi\" target=\"_blank\" rel=\"noopener\" class=\"inline-block w-full text-center px-5 py-2.5 text-sm font-semibold rounded-sm transition-colors hover:opacity-90\" style=\"background:var(--color-evergreen-950);color:var(--color-cream);border:1px solid var(--color-evergreen-950)\">Sponsor OpenGolfAPI</a></div></article><article class=\"rounded-sm p-8 flex flex-col h-full\" style=\"border-style:solid;border-color:var(--color-cream-darkest);border-width:1px;background:var(--color-cream)\"><p class=\"text-[13px] mb-2\" style=\"color:transparent\"> </p><h2 class=\"font-display text-2xl font-bold mb-3\" style=\"color:var(--color-ink)\">Major Sponsor</h2><div class=\"mb-6 flex items-baseline gap-2\"><span class=\"font-display font-bold\" style=\"font-size:clamp(32px, 3.5vw, 44px);line-height:1;color:var(--color-ink)\">$250</span><span class=\"text-sm\" style=\"color:var(--color-ink-muted)\">per month</span></div><dl class=\"space-y-4 mb-8 text-[15px]\" style=\"color:var(--color-ink)\"><div><dt class=\"text-[11px] font-semibold tracking-wider uppercase mb-1\" style=\"color:var(--color-ink-muted)\">Rate limit</dt><dd>1,000,000 requests per day.</dd></div><div><dt class=\"text-[11px] font-semibold tracking-wider uppercase mb-1\" style=\"color:var(--color-ink-muted)\">How to sign up</dt><dd>Pledge on Open Collective.</dd></div><div><dt class=\"text-[11px] font-semibold tracking-wider uppercase mb-1\" style=\"color:var(--color-ink-muted)\">Recognition</dt><dd>Your logo lives on the opengolfapi.org footer, and we mention you by name in every launch post.</dd></div></dl><div class=\"mt-auto\"><a href=\"https://opencollective.com/opengolfapi\" target=\"_blank\" rel=\"noopener\" class=\"inline-block w-full text-center px-5 py-2.5 text-sm font-semibold rounded-sm transition-colors hover:opacity-90\" style=\"background:transparent;color:var(--color-evergreen-950);border:1px solid var(--color-evergreen-950)\">Become a major sponsor</a></div></article></div><section class=\"mt-20 pt-10 border-t\" style=\"border-color:var(--color-rule, var(--color-cream-darkest))\"><p class=\"font-display italic text-[15px] mb-3\" style=\"color:var(--color-brass-700);font-variation-settings:&quot;opsz&quot; 14\">A note on the model</p><h2 class=\"font-display tracking-tight font-bold mb-5\" style=\"font-size:clamp(24px, 3vw, 34px);line-height:1.15\">Free and open <em style=\"color:var(--color-brass-700);font-style:italic\">under ODbL,</em> forever.</h2><p class=\"text-lg max-w-[720px] mb-4\" style=\"color:var(--color-ink-muted)\">All tiers are donations to a community-maintained open dataset. Any tier can be cancelled anytime. The dataset stays free and open under ODbL forever — these are thank-yous, not paywalls.</p><p class=\"text-lg max-w-[720px]\" style=\"color:var(--color-ink-muted)\">We run on a foundation model: pledges go to<!-- --> <a href=\"https://opencollective.com/opengolfapi\" target=\"_blank\" rel=\"noopener\" class=\"underline\">Open Collective</a> <!-- -->where the books are public, the bills are infrastructure and surveying, and nobody owns the data. If you ever stop liking us, you can take the dataset with you.</p></section></div><!--$--><!--/$--></main><footer class=\"border-t mt-20 px-6 py-12\" style=\"border-color:var(--color-cream-darkest);color:var(--color-ink-muted)\"><div class=\"max-w-[1100px] mx-auto grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8 text-sm mb-8\"><div><h4 class=\"font-display text-base font-semibold mb-3\" style=\"color:var(--color-ink)\">OpenGolfAPI</h4><p class=\"mb-2\">An open almanac of American golf.</p><span class=\"inline-block text-[11px] px-2 py-0.5 rounded-full font-semibold tracking-wider\" style=\"background:var(--color-cream-darker);color:var(--color-ink)\">ODbL 1.0</span></div><div><h4 class=\"font-display text-base font-semibold mb-3\" style=\"color:var(--color-ink)\">Browse</h4><a class=\"block py-0.5 hover:text-[var(--color-evergreen-950)]\" href=\"/\">All courses</a><a class=\"block py-0.5 hover:text-[var(--color-evergreen-950)]\" href=\"/search\">Search</a><a class=\"block py-0.5 hover:text-[var(--color-evergreen-950)]\" href=\"/near-me\">Near me</a><a class=\"block py-0.5 hover:text-[var(--color-evergreen-950)]\" href=\"/submit\">Submit a course</a><a class=\"block py-0.5 hover:text-[var(--color-evergreen-950)]\" href=\"/my-edits\">My contributions</a></div><div><h4 class=\"font-display text-base font-semibold mb-3\" style=\"color:var(--color-ink)\">Build</h4><a href=\"https://opengolfapi.org/#api\" class=\"block py-0.5 hover:text-[var(--color-evergreen-950)]\">API docs</a><a class=\"block py-0.5 hover:text-[var(--color-evergreen-950)]\" href=\"/pricing\">Pricing</a><a class=\"block py-0.5 hover:text-[var(--color-evergreen-950)]\" href=\"/api-keys\">Get an API key</a><a href=\"https://github.com/opengolfapi\" class=\"block py-0.5 hover:text-[var(--color-evergreen-950)]\">GitHub</a><a href=\"https://www.npmjs.com/package/@opengolfapi/mcp-server\" class=\"block py-0.5 hover:text-[var(--color-evergreen-950)]\">MCP server</a></div><div><h4 class=\"font-display text-base font-semibold mb-3\" style=\"color:var(--color-ink)\">Support</h4><a href=\"https://opencollective.com/opengolfapi\" class=\"block py-0.5 hover:text-[var(--color-evergreen-950)]\">Donate</a><a class=\"block py-0.5 hover:text-[var(--color-evergreen-950)]\" href=\"/contact\">Contact</a><a href=\"https://github.com/opengolfapi/opengolfapi/issues\" class=\"block py-0.5 hover:text-[var(--color-evergreen-950)]\">Report an issue</a><a class=\"block py-0.5 hover:text-[var(--color-evergreen-950)]\" href=\"/status\">Status</a><a class=\"block py-0.5 hover:text-[var(--color-evergreen-950)]\" href=\"/legal/privacy\">Privacy</a><a class=\"block py-0.5 hover:text-[var(--color-evergreen-950)]\" href=\"/legal/terms\">Terms</a></div></div><p class=\"max-w-[1100px] mx-auto pt-6 text-center text-xs border-t\" style=\"border-color:var(--color-cream-darkest)\">Data licensed under <a href=\"https://opendatacommons.org/licenses/odbl/1-0/\" class=\"underline\">ODbL 1.0</a> · Booking links are affiliate — we may earn a small commission at no cost to you.</p></footer><script src=\"/_next/static/chunks/0hvu8ydxmxc5p.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[79520,[\\\"/_next/static/chunks/001b~5_czkb82.js\\\",\\\"/_next/static/chunks/0zukl~qek1swj.js\\\"],\\\"\\\"]\\n3:I[22016,[\\\"/_next/static/chunks/001b~5_czkb82.js\\\",\\\"/_next/static/chunks/0zukl~qek1swj.js\\\"],\\\"\\\"]\\n36:I[68027,[\\\"/_next/static/chunks/001b~5_czkb82.js\\\",\\\"/_next/static/chunks/0zukl~qek1swj.js\\\"],\\\"default\\\",1]\\n:HL[\\\"/_next/static/chunks/0tbn~grm7is_3.css\\\",\\\"style\\\"]\\n:HL[\\\"/_next/static/media/54fc36028e2bb174-s.p.0nkps02--w45i.woff2\\\",\\\"font\\\",{\\\"crossOrigin\\\":\\\"\\\",\\\"type\\\":\\\"font/woff2\\\"}]\\n:HL[\\\"/_next/static/media/fa0520225c6f3d07-s.p.0_88erakuzr64.woff2\\\",\\\"font\\\",{\\\"crossOrigin\\\":\\\"\\\",\\\"type\\\":\\\"font/woff2\\\"}]\\n\"])</script><script>self.__next_f.push([1,\"0:{\\\"P\\\":null,\\\"c\\\":[\\\"\\\",\\\"pricing\\\"],\\\"q\\\":\\\"\\\",\\\"i\\\":false,\\\"f\\\":[[[\\\"\\\",{\\\"children\\\":[\\\"pricing\\\",{\\\"children\\\":[\\\"__PAGE__\\\",{}]}]},\\\"$undefined\\\",\\\"$undefined\\\",16],[[\\\"$\\\",\\\"$1\\\",\\\"c\\\",{\\\"children\\\":[[[\\\"$\\\",\\\"link\\\",\\\"0\\\",{\\\"rel\\\":\\\"stylesheet\\\",\\\"href\\\":\\\"/_next/static/chunks/0tbn~grm7is_3.css\\\",\\\"precedence\\\":\\\"next\\\",\\\"crossOrigin\\\":\\\"$undefined\\\",\\\"nonce\\\":\\\"$undefined\\\"}],[\\\"$\\\",\\\"script\\\",\\\"script-0\\\",{\\\"src\\\":\\\"/_next/static/chunks/001b~5_czkb82.js\\\